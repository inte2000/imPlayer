{
    "tasks": [
        {
            "label": "cmake-config-debug (MSVC C++20)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build/debug",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_TOOLCHAIN_FILE=E:/development/vcpkg/scripts/buildsystems/vcpkg.cmake"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "cmake-build-debug (MSVC C++20)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/debug",
                "--target",
                "iPlayer"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "cmake-config-test (MSVC C++20)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                ".",
                "-B",
                "build/test",
                "-G",
                "Ninja",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DBUILD_TESTING=ON",
                "-DCMAKE_TOOLCHAIN_FILE=E:/development/vcpkg/scripts/buildsystems/vcpkg.cmake"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "cmake-build-test (MSVC C++20)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build/test",
                "--target",
                "iPlayerTests"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "cmake-config-test (MSVC C++20)"
            ],
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}