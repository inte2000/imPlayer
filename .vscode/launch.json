{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) Debug with MSVC",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/debug/bin/imPlayer.exe",
            "args": [
                "-p",
                "--tui",
                "--filename=E:/workspace/iPlayer/test_music/302_-_Dune_II_-_DOS_-_Introduction.ogg"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],            
            "preLaunchTask": "cmake-build-debug (MSVC C++20)"
        },
        {
            "name": "(Windows) Test with MSVC",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/test/bin/imPlayerTests.exe",
            "args": [
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],            
            "preLaunchTask": "cmake-build-test (MSVC C++20)"
        }        
    ]
}